# ================================
# Data Cleaning Script for Customer Churn Dataset
# ================================

# 1. Import Libraries
import pandas as pd
import numpy as np

# 2. Load Raw Data
raw_data = pd.read_csv("customer_churn_rawdata.csv")
print("Raw Data Shape:", raw_data.shape)
raw_data.head()

# 3. Check Data Quality
print("\nMissing Values:\n", raw_data.isnull().sum())
print("\nDuplicate Rows:", raw_data.duplicated().sum())
print("\nData Types:\n", raw_data.dtypes)

# 4. Remove Duplicates
cleaned_data = raw_data.drop_duplicates()

# 5. Standardize Column Names
cleaned_data.columns = cleaned_data.columns.str.strip().str.lower().str.replace(" ", "_")

# 6. Convert Data Types
# Ensure numeric columns are properly typed
cleaned_data["tenure"] = pd.to_numeric(cleaned_data["tenure"], errors="coerce")
cleaned_data["monthlycharges"] = pd.to_numeric(cleaned_data["monthlycharges"], errors="coerce")
cleaned_data["totalcharges"] = pd.to_numeric(cleaned_data["totalcharges"], errors="coerce")

# Convert categorical columns to category dtype
categorical_cols = ["contract", "paymentmethod", "paperlessbilling", "churn"]
for col in categorical_cols:
    cleaned_data[col] = cleaned_data[col].astype("category")

# SeniorCitizen should be integer (0/1)
cleaned_data["seniorcitizen"] = cleaned_data["seniorcitizen"].astype(int)

# 7. Handle Missing Values (if any after conversion)
cleaned_data.fillna({
    "tenure": cleaned_data["tenure"].median(),
    "monthlycharges": cleaned_data["monthlycharges"].median(),
    "totalcharges": cleaned_data["totalcharges"].median()
}, inplace=True)

# 8. Save Cleaned Data
cleaned_data.to_csv("C:\\Users\khana\\.vscode\\Complete Business Analysis Project\\customer_churn_cleaned_data.csv", index=False)
print("Cleaned Data Shape:", cleaned_data.shape)

# 9. Summary Report
print("\nFinal Dataset Info:")
print(cleaned_data.info())
print("\nSample Data:\n", cleaned_data.head())
